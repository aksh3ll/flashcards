  "sentences": [
    { "id": "s1", "display": "妹が生まれた。", "hiragana": "いもうとがうまれた。", "fr": "Une petite sœur est née.", "en": "A younger sister was born." },
    { "id": "s2", "display": "長い線を引く。", "hiragana": "ながいせんをひく。", "fr": "Tracer une longue ligne.", "en": "To draw a long line." },
    { "id": "s3", "display": "汽車のたび。", "hiragana": "きしゃのたび。", "fr": "Un voyage en train à vapeur.", "en": "A steam train journey." },
    { "id": "s4", "display": "広い海。", "hiragana": "ひろいうみ。", "fr": "Une vaste mer.", "en": "A wide sea." },
    { "id": "s5", "display": "回り道をして帰る。", "hiragana": "まわりみちをしてかえる。", "fr": "Faire un détour pour rentrer chez soi.", "en": "To take a detour and go home." },
    { "id": "s6", "display": "ゆっくり歩く。", "hiragana": "ゆっくりあるく。", "fr": "Marcher lentement.", "en": "To walk slowly." },
    { "id": "s7", "display": "大きな魚をつる。", "hiragana": "おおきなさかなをつる。", "fr": "Pêcher un gros poisson.", "en": "To catch a big fish." },
    { "id": "s8", "display": "名前を書く。", "hiragana": "なまえをかく。", "fr": "Écrire son nom.", "en": "To write one's name." },
    { "id": "s9", "display": "元気にあそぶ。", "hiragana": "げんきにあそぶ。", "fr": "Jouer énergiquement.", "en": "To play energetically." },
    { "id": "s10", "display": "岩山をよじのぼる。", "hiragana": "いわやまをよじのぼる。", "fr": "Escalader une montagne rocheuse.", "en": "To scramble up a rocky mountain." },
    { "id": "s11", "display": "先生が教える。", "hiragana": "せんせいがおしえる。", "fr": "L'enseignant enseigne.", "en": "The teacher teaches." },
    { "id": "s12", "display": "光をあびる。", "hiragana": "ひかりをあびる。", "fr": "Se baigner dans la lumière.", "en": "To be bathed in light." },
    { "id": "s13", "display": "よい知らせがとどく。", "hiragana": "よいしらせがとどく。", "fr": "De bonnes nouvelles arrivent.", "en": "Good news arrives." },
    { "id": "s14", "display": "よく考える。", "hiragana": "よくかんがえる。", "fr": "Bien réfléchir.", "en": "To think carefully." },
    { "id": "s15", "display": "教室にもどる。", "hiragana": "きょうしつにもどる。", "fr": "Retourner dans la salle de classe.", "en": "To return to the classroom." },
    { "id": "s16", "display": "日光をあびる。", "hiragana": "にっこうをあびる。", "fr": "Se baigner dans la lumière du soleil.", "en": "To bathe in the sunlight." }
