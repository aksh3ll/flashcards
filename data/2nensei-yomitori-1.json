    { "id": "s3", "display": "先生に言う。", "hiragana": "せんせいにいう。", "fr": "Dire au professeur.", "en": "To tell the teacher." },
    { "id": "s4", "display": "公園に行く。", "hiragana": "こうえんにいく。", "fr": "Aller au parc.", "en": "To go to the park." },
    { "id": "s5", "display": "南のしま。", "hiragana": "みなみのしま。", "fr": "Une île du sud.", "en": "A southern island." },
